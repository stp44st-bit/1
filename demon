local function ToggleGhostActivity()
	GhostActivityToggle = not GhostActivityToggle
	if GhostActivityToggle then
		GhostActivityBtn.Text = "Activity: ON"
		GhostActivityBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
		task.spawn(function()
			local lastPos = ghostPart and ghostPart.Position or Vector3.new(0,0,0)
			while GhostActivityToggle do
				pcall(function()
					if ghostPart then
						local movement = (ghostPart.Position - lastPos).Magnitude
						lastPos = ghostPart.Position
						local level, color = "Low", Color3.fromRGB(0, 255, 0)
						if movement > 10 then level, color = "EXTREME", Color3.fromRGB(255, 0, 0)
						elseif movement > 5 then level, color = "High", Color3.fromRGB(255, 170, 0)
						elseif movement > 2 then level, color = "Medium", Color3.fromRGB(255, 255, 0) end
						GhostActivityBtn.Text = "Activity: " .. level
						GhostActivityBtn.BackgroundColor3 = color
					end
				end)
				task.wait(1)
			end
		end)
	else
		GhostActivityBtn.Text = "Activity Monitor"
		GhostActivityBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	end
end

