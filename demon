function UpdatePlrEsp()
	if PlayersEspToggle then
		for _, p in pairs(PS:GetPlayers()) do
			if p.Character then
				local HumanoidRootPart = p.Character:FindFirstChild("HumanoidRootPart")
				if HumanoidRootPart then
					local Esp1 = HumanoidRootPart:FindFirstChild("Ducko355PlrBil")
					local Esp2 = HumanoidRootPart:FindFirstChild("Ducko355PlrEsp")

					task.spawn(function()
						if p:GetAttribute("Dead") == true then
							for _, v in pairs(p.Character:GetDescendants()) do
								if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
									v.Transparency = 0
								end
								if v.Name == "Ducko355PlrBil" then
									local Txt = v:FindFirstChild("TextLabel")
									if Txt then Txt.Text = p.DisplayName .. "(Dead)" end
								end
							end
						end
					end)

					if not Esp1 and not Esp2 then
						local bb = Instance.new("BillboardGui")
						local tl = Instance.new("TextLabel")
						local hl2 = Instance.new("Highlight")

						bb.Name = "Ducko355PlrBil"
						bb.Parent = HumanoidRootPart
						bb.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
						bb.Active = true
						bb.AlwaysOnTop = true
						bb.Size = UDim2.new(0, 100, 0, 40)
						bb.LightInfluence = 0
						bb.Brightness = 1
						bb.Adornee = HumanoidRootPart

						tl.Parent = bb
						tl.BackgroundTransparency = 1
						tl.BorderSizePixel = 0
						tl.Size = UDim2.new(1, 0, 1, 0)
						tl.Font = Enum.Font.SourceSans
						tl.TextColor3 = Color3.fromRGB(0, 170, 255)
						tl.TextScaled = true
						tl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
						tl.TextStrokeTransparency = 0
						tl.Text = p.DisplayName

						hl2.Name = "Ducko355PlrEsp"
						hl2.Parent = HumanoidRootPart
						hl2.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
						hl2.OutlineColor = Color3.fromRGB(0, 170, 255)
						hl2.FillTransparency = 1
						hl2.OutlineTransparency = 0
						hl2.Adornee = p.Character
					end
				end
			end
		end
	else
		for _, p in pairs(PS:GetPlayers()) do
			if p.Character then
				local HumanoidRootPart = p.Character:FindFirstChild("HumanoidRootPart")
				if HumanoidRootPart then
					local Esp1 = HumanoidRootPart:FindFirstChild("Ducko355PlrBil")
					local Esp2 = HumanoidRootPart:FindFirstChild("Ducko355PlrEsp")
					if Esp1 then Esp1:Destroy() end
					if Esp2 then Esp2:Destroy() end
				end
			end
		end
	end
end

