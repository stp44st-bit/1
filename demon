}

local function IdentifyGhost()
	pcall(function()
		local evidenceFound = {}
		if Handprints.Text:find("Yes") then table.insert(evidenceFound, "Handprints") end
		if SpiritBox.Text:find("Yes") then table.insert(evidenceFound, "SpiritBox") end
		if GhostOrb.Text:find("Yes") then table.insert(evidenceFound, "GhostOrb") end
		if GhostWriting.Text:find("Yes") then table.insert(evidenceFound, "GhostWriting") end
		if LaserProjector.Text:find("Yes") then table.insert(evidenceFound, "LaserProjector") end

		local emfLevel = tonumber(EMF.Text:match("%d+")) or 0
		if emfLevel >= 5 then table.insert(evidenceFound, "EMF5") end

		local tempValue = tonumber(Temperature.Text:match("%-?%d+%.?%d*")) or 20
		if tempValue <= 0 then table.insert(evidenceFound, "FreezingTemps") end

		local possibleGhosts = {}
		for ghostName, ghostEvidence in pairs(GhostDatabase) do
			local matches = true
			for _, foundEvi in ipairs(evidenceFound) do
				local hasEvidence = false
				for _, ghostEvi in ipairs(ghostEvidence) do
					if ghostEvi == foundEvi then hasEvidence = true break end
				end
				if not hasEvidence then matches = false break end
			end
			if matches then table.insert(possibleGhosts, ghostName) end
		end

		local resultText
		if #evidenceFound == 0 then
			resultText = "No evidence found yet"
		elseif #possibleGhosts == 0 then
			resultText = "No matching ghost (check evidence)"
		elseif #possibleGhosts == 1 then
			resultText = "Ghost: " .. possibleGhosts[1] .. " (CONFIRMED!)"
		else
			resultText = "Possible: " .. table.concat(possibleGhosts, ", ")
		end

		GhostIdentifyLabel.Text = resultText
		game:GetService("StarterGui"):SetCore("SendNotification", {
			Title = "Ghost Identifier", Text = resultText, Duration = 5
		})
	end)
end

