-- TP ALL ITEMS HERE
local function TpAllItemsHere()
	pcall(function()
		local count = 0
		local ItemFolder = workspace:FindFirstChild("Items")
		if ItemFolder and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
			local myPos = plr.Character.HumanoidRootPart.CFrame
			for _, item in pairs(ItemFolder:GetChildren()) do
				if item:IsA("Model") then
					pcall(function()
						local handle = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart")
