-- AUTO PARRY SYSTEM (OPTIMIZED)
--------------------------------------------------------------
local ActiveProjectiles = {}
local ParryRemotes = {}

task.spawn(function()
	pcall(function()
		local descendants = game:GetService("ReplicatedStorage"):GetDescendants()
		for i = 1, #descendants do
			local remote = descendants[i]
			if remote:IsA("RemoteEvent") and (remote.Name:lower():find("parry") or remote.Name:lower():find("block") or remote.Name:lower():find("deflect")) then
				table.insert(ParryRemotes, remote)
			end
			if i % 500 == 0 then task.wait() end
		end
	end)
end)

local function CheckProjectile(obj)
	if obj:IsA("BasePart") then
		local name = obj.Name:lower()
		if name:find("bullet") or name:find("projectile") or name:find("slash") or name:find("attack") then
			ActiveProjectiles[obj] = true
		end
	end
end

task.spawn(function()
	local descendants = workspace:GetDescendants()
	for i = 1, #descendants do
		CheckProjectile(descendants[i])
		if i % 500 == 0 then task.wait() end
	end
end)

Connections.ProjAdd = workspace.DescendantAdded:Connect(function(obj)
	CheckProjectile(obj)
end)

Connections.ProjRem = workspace.DescendantRemoving:Connect(function(obj)
	ActiveProjectiles[obj] = nil
end)

task.spawn(function()
	while not IsUiClosed do
		if State.AutoParry then
			pcall(function()
				local char = plr.Character
				if char and char:FindFirstChild("HumanoidRootPart") then
					local myPos = char.HumanoidRootPart.Position
					
					for obj, _ in pairs(ActiveProjectiles) do
						if obj and obj.Parent then
							local dist = (obj.Position - myPos).Magnitude
							if dist < 20 then
								pcall(function()
									game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.F, false, game)
									task.wait(0.05)
									game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.F, false, game)
								end)
								for _, remote in pairs(ParryRemotes) do
									pcall(function() remote:FireServer() end)
								end
								ActiveProjectiles[obj] = nil
								break
							end
						else
							ActiveProjectiles[obj] = nil
						end
					end
				end
			end)
		end
		task.wait(0.05)
	end
end)

