	if State.HealthBar then
		local hbb = Instance.new("BillboardGui")
		hbb.Name = "RLHUB_HP"
		hbb.Parent = game:GetService("CoreGui")
		hbb.Adornee = hrp
		hbb.AlwaysOnTop = true
		hbb.Size = UDim2.new(0, 60, 0, 8)
		hbb.StudsOffset = Vector3.new(0, 4.5, 0)
		hbb.LightInfluence = 0

		local bgBar = Instance.new("Frame")
		bgBar.Parent = hbb
		bgBar.Size = UDim2.new(1, 0, 1, 0)
		bgBar.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
		bgBar.BorderSizePixel = 0
		local bgCorner = Instance.new("UICorner")
		bgCorner.CornerRadius = UDim.new(0, 3)
		bgCorner.Parent = bgBar

		local hpBar = Instance.new("Frame")
		hpBar.Name = "HPFill"
		hpBar.Parent = bgBar
		hpBar.Size = UDim2.new(1, 0, 1, 0)
		hpBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
		hpBar.BorderSizePixel = 0
		local hpCorner = Instance.new("UICorner")
		hpCorner.CornerRadius = UDim.new(0, 3)
		hpCorner.Parent = hpBar

		table.insert(ESPObjects, hbb)
