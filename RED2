Connections.MainLoop = RS.Heartbeat:Connect(function()
	if IsUiClosed then return end
	pcall(function()
		local char = plr.Character
		if not char then return end
		local humanoid = char:FindFirstChild("Humanoid")
		local hrp = char:FindFirstChild("HumanoidRootPart")

		-- Speed
		if State.Speed and humanoid then
			humanoid.WalkSpeed = 16 * State.SpeedMult
		end

		-- Fly
		if State.Fly and FlyBV and FlyBG and hrp then
			local cam = Camera
			FlyBG.CFrame = cam.CFrame
			local dir = Vector3.zero
			if UIS:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
			if UIS:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
			if UIS:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
			if UIS:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
			if UIS:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
			if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0, 1, 0) end
			FlyBV.Velocity = dir.Magnitude > 0 and dir.Unit * State.FlySpeed or Vector3.zero
		end

		-- Noclip
		if State.Noclip and char then
			for _, p in pairs(char:GetDescendants()) do
				if p:IsA("BasePart") then p.CanCollide = false end
			end
		end

		-- Inf Health
		if State.InfHealth and humanoid then
			humanoid.Health = humanoid.MaxHealth
		end

		-- Anti-Slow
		if State.AntiSlow and humanoid then
			if humanoid.WalkSpeed < 16 then humanoid.WalkSpeed = 16 end
		end

		-- Anti-Void
		if State.AntiVoid and hrp then
			if hrp.Position.Y < -50 then
				hrp.CFrame = CFrame.new(0, 50, 0)
			end
		end

		-- Auto BHop
		if State.AutoBHop and humanoid then
			if humanoid.MoveDirection.Magnitude > 0 then
				humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
			end
		end

		-- Freecam movement
		if State.Freecam then
			local cam = Camera
			local dir = Vector3.zero
			local speed = 30
			if UIS:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
			if UIS:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
			if UIS:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
			if UIS:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
			if UIS:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
			if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0, 1, 0) end
			if dir.Magnitude > 0 then cam.CFrame = cam.CFrame + dir.Unit * speed * 0.016 end
		end

		-- Aim Assist
		if State.AimAssist and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
			local target = GetClosestEnemyToMouse(State.AimFOV)
			if target and target.Character and target.Character:FindFirstChild("Head") then
				local head = target.Character.Head
				local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, head.Position)
				-- Lerp for smoothness instead of instant snapping (0.5 is smoothness factor)
				Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 0.5)
			end
		end

		-- Update ESP distances
		if State.PlayerESP and hrp then
			for _, obj in pairs(ESPObjects) do
				if obj:IsA("BillboardGui") and obj:FindFirstChild("DistLabel") then
					local adornee = obj.Adornee
					if adornee then
						local dist = (adornee.Position - hrp.Position).Magnitude
						obj.DistLabel.Text = math.floor(dist) .. "m"
					end
				end
			end
		end

		-- Update health bars
		for _, obj in pairs(ESPObjects) do
			if obj:IsA("BillboardGui") and obj.Name == "RLHUB_HP" then
				local adornee = obj.Adornee
				if adornee and adornee.Parent then
					local hum = adornee.Parent:FindFirstChild("Humanoid")
					if hum then
						local fill = obj:FindFirstChild("Frame", true)
						if fill then
							local hpFill = fill:FindFirstChild("HPFill")
							if hpFill then
								local pct = hum.Health / hum.MaxHealth
								hpFill.Size = UDim2.new(math.clamp(pct, 0, 1), 0, 1, 0)
								hpFill.BackgroundColor3 = Color3.fromRGB(255 * (1 - pct), 255 * pct, 0)
							end
						end
					end
				end
			end
		end

		-- Hitbox update
		if State.Hitbox then UpdateHitbox() end

		-- Inf Dash / Inf Grapple (reset cooldowns)
		if State.InfDash or State.InfGrapple then
			for _, v in pairs(char:GetDescendants()) do
				if v:IsA("NumberValue") and (v.Name:lower():find("cooldown") or v.Name:lower():find("dash") or v.Name:lower():find("grapple") or v.Name:lower():find("charge")) then
					v.Value = 0
				end
			end
			-- Also check PlayerGui for cooldown UI
			pcall(function()
				for _, v in pairs(plr.PlayerGui:GetDescendants()) do
					if v:IsA("NumberValue") and (v.Name:lower():find("cooldown") or v.Name:lower():find("dash") or v.Name:lower():find("grapple")) then
						v.Value = 0
					end
				end
			end)
		end

		-- FPS Display
		if State.FPSDisplay then
			local fps = math.floor(1 / RS.Heartbeat:Wait())
			local ping = math.floor(plr:GetNetworkPing() * 1000)
			FPSLabel.Text = "FPS: " .. fps .. " | Ping: " .. ping .. "ms"
		end
	end)
end)

