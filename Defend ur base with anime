-- MUTATION TIMER
--------------------------------------------------------------
task.spawn(function()
	while not IsUiClosed do
		if State.MutTimer or State.MutAlert then
			local now = os.date("*t")
			local min = now.min
			local sec = now.sec
			
			-- Mutations happen at :15, :30, :45
			local nextMut
			if min < 15 then nextMut = 15
			elseif min < 30 then nextMut = 30
			elseif min < 45 then nextMut = 45
			else nextMut = 60 end -- next hour :00 ГўвЂ вЂ™ :15
			
			local remaining
			if nextMut == 60 then
				remaining = (60 - min) * 60 + (15 * 60) - sec
			else
				remaining = (nextMut - min) * 60 - sec
			end
			
			local minsLeft = math.floor(remaining / 60)
			local secsLeft = remaining % 60
			
			local mutNames = {"Dragonborn (:15)", "Beast (:30)", "Arrancar (:45)"}
			local mutIndex = nextMut == 15 and 1 or (nextMut == 30 and 2 or 3)
			if nextMut == 60 then mutIndex = 1 end
			
			if State.MutTimer then
				MutLabel.Text = string.format("ГўВЏВ° %s in %02d:%02d", mutNames[mutIndex], minsLeft, secsLeft)
			end
			
			-- Alert when 30 seconds before mutation
			if State.MutAlert and remaining <= 30 and remaining > 28 then
				Notify("Г°ЕёвЂќВҐ MUTATION SOON!", mutNames[mutIndex] .. " in 30 seconds!", 5)
			end
		end
		task.wait(1)
	end
end)

