-- REMOTE FINDER (Г ВёвЂћГ В№вЂ°Г Вёв„ўГ ВёВ«Г ВёВІ Remote Г ВёвЂ”Г ВёВµГ В№в‚¬Г ВёвЂќГ ВёВµГ ВёВўГ ВёВ§ Г В№вЂћГ ВёВЎГ В№Л†Г ВёвЂ№Г В№вЂ°Г ВёВі)
--------------------------------------------------------------
local CachedRemotes = {}
local function FindRemote(name)
	if CachedRemotes[name] then return CachedRemotes[name] end
	local remote = nil
	pcall(function()
		for _, v in pairs(ReplicatedStorage:GetDescendants()) do
			if (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) and v.Name:lower():find(name:lower()) then
				remote = v
				break
			end
		end
	end)
	if remote then CachedRemotes[name] = remote end
	return remote
end

-- Pre-cache common remotes on startup (async to avoid crash)
task.spawn(function()
	task.wait(2)
	pcall(function()
		local names = {"summon", "merge", "upgrade", "collect", "rebirth", "trait", "craft", "clone", "place", "sell", "start", "skip", "roll"}
		for _, n in ipairs(names) do
			FindRemote(n)
			task.wait(0.1)
		end
	end)
end)

--------------------------------------------------------------
-- HELPER: Fire remote safely
--------------------------------------------------------------
local function FireRemote(name, ...)
	local remote = FindRemote(name)
	if remote then
		pcall(function()
			if remote:IsA("RemoteEvent") then
				remote:FireServer(...)
			elseif remote:IsA("RemoteFunction") then
				remote:InvokeServer(...)
			end
		end)
		return true
	end
	return false
end

