local function CreateToggleBtn(parent, name, text, position)
	local btn = Instance.new("TextButton")
	btn.Name = name
	btn.Parent = parent
	btn.Position = position
	btn.Size = UDim2.new(0.31, -4, 0, 34)
	btn.BackgroundColor3 = Color3.fromRGB(38, 38, 50)
	btn.BorderSizePixel = 0
	btn.Font = Enum.Font.GothamSemibold
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(220, 220, 220)
	btn.TextScaled = true
	btn.TextSize = 11
	
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = btn
	
	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(60, 60, 75)
	stroke.Thickness = 1.2
	stroke.Parent = btn
	
	return btn
end

local function SetBtnOn(btn)
	btn.BackgroundColor3 = Color3.fromRGB(255, 120, 30)
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
end

local function SetBtnOff(btn)
	btn.BackgroundColor3 = Color3.fromRGB(38, 38, 50)
	btn.TextColor3 = Color3.fromRGB(220, 220, 220)
end

local function CreateSectionTitle(parent, text, position)
	local label = Instance.new("TextLabel")
	label.Parent = parent
	label.Position = position
	label.Size = UDim2.new(1, 0, 0, 22)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.Text = text
	label.TextColor3 = Color3.fromRGB(255, 160, 60)
	label.TextScaled = true
	label.TextXAlignment = Enum.TextXAlignment.Left
	return label
end

local function Notify(title, text, duration)
	StarterGui:SetCore("SendNotification", {
		Title = title, Text = text, Duration = duration or 3
	})
end

