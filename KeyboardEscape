local function SwitchTab(n)
	for i, p in ipairs(Pages) do
		p.Visible = (i == n)
		tabButtons[i].BackgroundColor3 = (i == n) and Color3.fromRGB(220, 100, 160) or Color3.fromRGB(40, 25, 35)
		tabButtons[i].BackgroundTransparency = (i == n) and 0 or 0.3
	end
end
for i, t in ipairs(tabButtons) do t.MouseButton1Click:Connect(function() SwitchTab(i) end) end

local CachedRemotes = {}
local SearchedNames = {}
local function Fire(name)
	if not SearchedNames[name] then
		SearchedNames[name] = true
		for _, v in pairs(RepStorage:GetDescendants()) do
			if (v.ClassName == "RemoteEvent" or v.ClassName == "RemoteFunction") and string.find(string.lower(v.Name), name) then
				CachedRemotes[name] = v; break
			end
		end
	end
	local r = CachedRemotes[name]
	if r then
		pcall(function()
			if r.ClassName == "RemoteEvent" then r:FireServer() else r:InvokeServer() end
		end)
	end
end

local function SafeTP(pos)
