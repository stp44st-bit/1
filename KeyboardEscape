	while not IsUiClosed do
		if S.AutoWalk then pcall(function() Fire("walk"); Fire("step"); Fire("speed") end) end
		if S.AutoTread then pcall(function() Fire("treadmill"); Fire("train") end) end
		if S.AutoWin then pcall(function() Fire("win"); Fire("finish") end) end
		if S.AutoRebirth then pcall(function() Fire("rebirth") end) end
		if S.AutoCollect then pcall(function() Fire("collect"); Fire("claim") end) end
		task.wait(0.1)
	end
end)

