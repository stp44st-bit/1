local function CreateBtn(parent, name, text, position)
	local btn = Instance.new("TextButton")
	btn.Name = name
	btn.Parent = parent
	btn.Position = position
	btn.Size = UDim2.new(0.31, -4, 0, 34)
	btn.BackgroundColor3 = Color3.fromRGB(45, 30, 40)
	btn.BorderSizePixel = 0
	btn.Font = Enum.Font.GothamSemibold
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(230, 220, 225)
	btn.TextScaled = true
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
	return btn
end

local function BtnOn(btn)
	btn.BackgroundColor3 = Color3.fromRGB(220, 100, 160)
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
end

local function BtnOff(btn)
	btn.BackgroundColor3 = Color3.fromRGB(45, 30, 40)
